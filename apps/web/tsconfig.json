{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "target": "ES2017",
    "paths": {
      "@/*": ["./src/*"],
      "public/*": ["./public/*"],
      "@ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "svg.d.ts",
    "svgr.d.ts",
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next.config.ts",
    "postcss.config.mjs",
    "src/i18n/*.ts"
  ],
  "exclude": ["node_modules"],
  "references": [{ "path": "../../packages/ui" }]
}
